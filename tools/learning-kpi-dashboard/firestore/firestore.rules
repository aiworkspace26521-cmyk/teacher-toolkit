rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // kpi_events: 僅可新增+讀取，不可修改/刪除（事件溯源）
    match /kpi_events/{eventId} {
      allow create: if request.resource.data.keys().hasAll(['studentId', 'action', 'timestamp']);
      allow read: if true;
      allow update, delete: if false;
    }

    // kpi_students: 學生可讀寫自己的快取資料
    match /kpi_students/{studentId} {
      allow read: if true;
      allow write: if request.resource.data.studentId == studentId;
    }

    // kpi_subjects: 公開唯讀
    match /kpi_subjects/{subjectId} {
      allow read: if true;
      allow write: if false;
    }

    // kpi_achievements: 公開唯讀
    match /kpi_achievements/{achievementId} {
      allow read: if true;
      allow write: if false;
    }

    // gyms: 公開唯讀（道館資料）
    match /gyms/{gymId} {
      allow read: if true;
      allow write: if false;
    }

    // trade_offers: 學生名義控制（無 Auth，改用欄位存在檢查）
    match /trade_offers/{offerId} {
      allow read: if true;
      allow create: if request.resource.data.fromId is string
                    && request.resource.data.toId is string;
      allow update: if resource.data.fromId is string
                    || resource.data.toId is string;
      allow delete: if resource.data.fromId is string;
    }

    // pvp_ranking: 公開讀取，學生可寫入自己的排名
    match /pvp_ranking/{studentId} {
      allow read: if true;
      allow write: if request.resource.data.elo is number;
    }

    // pvp_battles: 挑戰者/防禦者讀寫各自戰鬥
    match /pvp_battles/{battleId} {
      allow read: if true;
      allow create: if request.resource.data.challengerId is string
                    && request.resource.data.defenderId is string;
      allow update: if resource.data.challengerId is string;
      allow delete: if false;
    }

    // 其餘全部拒絕
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
